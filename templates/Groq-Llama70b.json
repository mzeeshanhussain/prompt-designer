{
  "name": "Groq Llama 70b",
  "description": "Send a prompt to Groq's API using llama-3.3-70b-versatile. Fast inference, high quality.",
  "url": "https://api.groq.com/openai/v1/chat/completions",
  "method": "POST",
  "headers": {
    "Content-Type": "application/json",
    "Authorization": "Bearer {{GroqToken}}"
  },
  "body": {
    "model": "llama-3.3-70b-versatile",
    "messages": [
      {
        "role": "user",
        "content": "{{Prompt}}"
      }
    ],
    "temperature": 0.7
  },
  "responsePath": "choices[0].message.content"
}
